#!/bin/sh
# Pre-commit guard: ensure index.html cache-bust hashes (?v=…) match the actual
# file contents, so a changed .js/.css can never be committed with a stale ?v
# that leaves users on a cached old copy.
#
# Enable once per clone:   git config core.hooksPath .githooks
# (Skips cleanly if PowerShell is unavailable, e.g. on a CI checkout.)

if command -v pwsh >/dev/null 2>&1; then
  PS=pwsh
elif command -v powershell.exe >/dev/null 2>&1; then
  PS=powershell.exe
elif command -v powershell >/dev/null 2>&1; then
  PS=powershell
else
  echo "pre-commit: PowerShell not found — skipping cachebust check."
  exit 0
fi

"$PS" -NoProfile -ExecutionPolicy Bypass -File "cachebust.ps1" -Check
if [ $? -ne 0 ]; then
  echo ""
  echo "pre-commit: cache-bust hashes are stale."
  echo "  Run  ./cachebust.ps1  then re-stage index.html and commit again."
  exit 1
fi
exit 0
